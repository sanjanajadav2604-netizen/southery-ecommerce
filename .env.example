# MongoDB (required for orders & accounts)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=southery

# Auth
JWT_SECRET=use-a-long-random-secret-here

# Razorpay (live or test key id — secret stays server-side only for webhooks)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Emails via Resend (https://resend.com) — optional but recommended
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Southery Sentie <orders@yourdomain.com>

# Your live site URL (for links in emails)
FRONTEND_URL=https://your-domain.vercel.app
